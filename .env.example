# Telegram Bot Token (получите от @BotFather) - ОБЯЗАТЕЛЬНО!
TELEGRAM_TOKEN=your_telegram_token_here

# Webhook URL (необязательно если используете Railway)
# Если используете Railway, оставьте пусто - будет использована RAILWAY_PUBLIC_DOMAIN
WEBHOOK_URL=

# или для локального тестирования с ngrok:
# WEBHOOK_URL=https://your-ngrok-url/

# Port (по умолчанию 8443 на Railway)
PORT=8443
